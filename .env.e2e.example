# ─── E2E Test Environment ────────────────────────────────────────────────────
#
# Copy this file to .env.local and fill in the values before running E2E tests.
#
# IMPORTANT: .env.local is gitignored. Never commit secrets.
#
# Quick start (neo3-privatenet-docker pre-funded account):
#   E2E_TEST_ACCOUNT_ADDRESS=NV1Q1dTdvzPbThPbSFz7zudTmsmgnCwX6c
#   E2E_TEST_ACCOUNT_WIF=L3cNMQUSrvUrHx1MzacwHiUeCWzqK2MLt5fPvJj9mz6L2rzYZpok

# ─── Neo N3 private devnet (neo3-privatenet-docker) ──────────────────────────
NEXT_PUBLIC_NEO_RPC_URL=http://localhost:10332

# ─── TokenFactory contract (auto-deployed if missing when E2E_AUTO_DEPLOY=true) ─
# NEXT_PUBLIC_FACTORY_CONTRACT_HASH=0x...

# ─── E2E test account (docker pre-funded account) ────────────────────────────
E2E_TEST_ACCOUNT_ADDRESS=NV1Q1dTdvzPbThPbSFz7zudTmsmgnCwX6c
E2E_TEST_ACCOUNT_WIF=L3cNMQUSrvUrHx1MzacwHiUeCWzqK2MLt5fPvJj9mz6L2rzYZpok

# ─── E2E automation flags ─────────────────────────────────────────────────────
# E2E_RESET_CHAIN=true    — docker compose down -v + up -d before test run
# E2E_AUTO_DEPLOY=true    — auto-deploy TokenFactory if hash is missing/stale
