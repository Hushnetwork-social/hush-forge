# =============================================================================
# Forge — Environment Variables
# Copy this file to .env.local and fill in the values.
# =============================================================================

# Neo N3 RPC endpoint
# NeoExpress default: http://localhost:10332
# Testnet: https://testnet1.neo.coz.io:443
NEXT_PUBLIC_NEO_RPC_URL=http://localhost:10332

# TokenFactory contract hash (0x-prefixed, 42 chars)
# Get this after deploying the factory via neoxp batch
NEXT_PUBLIC_FACTORY_CONTRACT_HASH=0x

# Transaction polling configuration
# How long to wait for confirmation before timing out (ms)
NEXT_PUBLIC_TX_POLLING_TIMEOUT_MS=300000
# How often to check for confirmation (ms)
NEXT_PUBLIC_TX_POLLING_INTERVAL_MS=5000

# NeoTube explorer base URL
# Testnet:  https://testnet.neotube.io
# Mainnet:  https://neotube.io
NEXT_PUBLIC_NEOTUBE_BASE_URL=https://testnet.neotube.io

# =============================================================================
# E2E Test Configuration (not used at runtime — only for npm run test:e2e)
# =============================================================================

# NeoExpress test account (alice) — export with:
#   neoxp wallet export alice --input hush-neo-contracts/devnet/devnet.neo-express
E2E_TEST_ACCOUNT_ADDRESS=
E2E_TEST_ACCOUNT_WIF=
