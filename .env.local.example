# =============================================================================
# Forge — Environment Variables
# Copy this file to .env.local and fill in the values.
#
# RPC URL: For MainNet and TestNet, the app uses the wallet's canonical public
# RPC endpoints automatically — no URL config needed.
# For private / local networks (e.g. neo3-privatenet-docker), set
# NEXT_PUBLIC_NEO_RPC_URL so the app can poll for TX confirmation and read
# chain state (balance fallback, contract-deployed checks, etc.).
# =============================================================================

# RPC configuration for private/local networks ONLY.
# Leave blank for MainNet / TestNet — those use known public endpoints.
#
# Pattern: browser fetches /api/rpc (same origin, no CORS issues).
# Next.js server proxies to NEO_RPC_TARGET (server-to-server, no CORS).
NEXT_PUBLIC_NEO_RPC_URL=/api/rpc
NEO_RPC_TARGET=http://127.0.0.1:10332

# TokenFactory contract hash (0x-prefixed, 42 chars).
# Leave as 0x — the app will prompt the user to deploy it if missing,
# and will save the hash to localStorage after deployment.
# You can set this to skip the deploy prompt if you already have a factory.
NEXT_PUBLIC_FACTORY_CONTRACT_HASH=0x

# Transaction polling configuration
NEXT_PUBLIC_TX_POLLING_TIMEOUT_MS=300000
NEXT_PUBLIC_TX_POLLING_INTERVAL_MS=5000

# NeoTube explorer base URL (used for transaction links in the UI)
# Testnet:  https://testnet.neotube.io
# Mainnet:  https://neotube.io
NEXT_PUBLIC_NEOTUBE_BASE_URL=https://testnet.neotube.io

# =============================================================================
# E2E Test Configuration (not used at runtime — only for npm run test:e2e)
# =============================================================================
E2E_TEST_ACCOUNT_ADDRESS=
E2E_TEST_ACCOUNT_WIF=
