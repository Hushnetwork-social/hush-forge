# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Integration test wallet profiles — regenerated by npm run setup:wallet-profile
/e2e/wallet-profile/
/e2e/wallet-profile-*/
/e2e/wallet-profile-tmp-*/
/e2e/wallet-profile-setup-tmp/
/e2e/wallet-setup-debug/

# Integration test local credentials — never commit
/e2e/integration/.env.integration

# Local NeoLine probe/debug artifacts
/e2e/*probe*.png
/e2e/*inspect*.png
/e2e/importtest*.png
/e2e/importroute.png

# Integration test reports / artifacts
/playwright-report-integration/
/e2e/integration/playwright-report-integration/

# BDD generated specs (regenerated by bddgen on every test run)
/.features-gen/

# Playwright test output (screenshots, traces, HTML report)
/playwright-report/
/test-results/
