{
  "name": "hush-forge",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "dev:wallet-harness": "tsx tools/forge-wallet-harness/dev-server.ts",
    "lint": "eslint",
    "test:run": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:e2e": "bddgen && playwright test",
    "test:e2e:headed": "bddgen && playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "test:integration": "playwright test --config e2e/integration/playwright.config.ts",
    "test:integration:report": "playwright show-report playwright-report-integration",
    "verify:contracts": "node scripts/verify-contract-artifacts.mjs",
    "setup:test-profile": "powershell -ExecutionPolicy Bypass -File e2e/setup-test-profile.ps1",
    "setup:wallet-profile": "npx ts-node --project tsconfig.json e2e/setup-neoline-wallet.ts"
  },
  "dependencies": {
    "@cityofzion/appkit-neo3-adapter": "^1.0.0",
    "@reown/appkit": "^1.8.19",
    "@reown/walletkit": "^1.5.5",
    "lightweight-charts": "^5.1.0",
    "next": "16.2.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@cityofzion/neon-js": "^5.9.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "jsdom": "^28.1.0",
    "playwright-bdd": "^8.5.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.0.18",
    "ws": "^8.20.0"
  },
  "overrides": {
    "axios": "1.16.0",
    "lodash": "4.18.1",
    "postcss": "8.5.14",
    "uuid": "11.1.1"
  }
}
